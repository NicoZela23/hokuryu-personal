# Database path (SQLite file — created automatically on first run)
DB_PATH=./data/garden.db

# LLM enrichment — all optional, the app works without any of these.
# The first configured provider wins (priority: Anthropic → OpenRouter → Ollama).
#
# Recommended: OpenRouter with Perplexity Sonar (has live web search built in)
OPENROUTER_API_KEY=sk-or-...
OPENROUTER_MODEL=perplexity/sonar-pro

# Anthropic (Claude)
ANTHROPIC_API_KEY=sk-ant-...
ANTHROPIC_MODEL=claude-haiku-4-5-20251001

# Ollama (local — used as fallback if no cloud key is set)
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=llama3.2
