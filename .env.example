# ── Supabase ──────────────────────────────────────────────────
# From: supabase.com → project → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://[project-ref].supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=       # NEVER expose to client/browser

# Supabase Postgres — use the Transaction Pooler URL (port 6543) for Vercel/serverless
# From: supabase.com → project → Settings → Database → Connection pooling → Transaction mode
DATABASE_URL=postgresql://postgres.[project-ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres

# ── LLM (optional — app works without any of these) ───────────
# Recommended: OpenRouter with Perplexity Sonar (live web search)
OPENROUTER_API_KEY=
OPENROUTER_MODEL=perplexity/sonar-pro

# Anthropic (Claude)
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-haiku-4-5-20251001

# Ollama (local)
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=llama3.2

# ── Monitoring (optional — app works without this) ────────────
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_AUTH_TOKEN=

# ── App ───────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
